  "s_body_e": "<div id=\"contenedor-sorteo\" style=\"max-width: 500px; margin: 30px auto; padding: 15px; background: #1a1a1a; border-radius: 12px; border: 1px solid #333; text-align: center;\">\n    <h3 id=\"titulo-sorteo\" style=\"color: #ffd700; margin-bottom: 15px;\">Cargando números...</h3>\n    <div id=\"grid-sorteo\" style=\"display: grid; grid-template-columns: repeat(10, 1fr); gap: 6px;\"></div>\n</div>\n\n<script>\n    (async function() {\n        const WHATSAPP = \"5493764369001\";\n        const grid = document.getElementById(\"grid-sorteo\");\n        const titulo = document.getElementById(\"titulo-sorteo\");\n\n        // LISTA DE RESPALDO: Se usará SOLO si da error al cargar el archivo data.json localmente\n        let vendidos = []; \n\n        try {\n            // Intenta buscar los datos reales en GitHub\n            const respuesta = await fetch('data.json', { cache: \"no-store\" });\n            if (respuesta.ok) {\n                const datos = await respuesta.json();\n                vendidos = datos.vendidos;\n                console.log(\"Datos cargados con éxito desde data.json\");\n            } else {\n                console.warn(\"No se encontró data.json, usando lista de respaldo.\");\n            }\n        } catch (error) {\n            // Si estás en tu PC local, caerá aquí por el bloqueo CORS, pero IGUAL cargará el tablero\n            console.log(\"Modo local detectado (CORS). Usando lista de respaldo.\");\n        }\n\n        // Renderizado del tablero (Garantizado que funcione en PC y en Web)\n        titulo.innerText = \"Elegí tu número:\";\n        grid.innerHTML = \"\"; \n\n        for (let i = 0; i < 100; i++) {\n            const n = String(i).padStart(2, '0');\n            const estaVendido = vendidos.includes(n);\n            const btn = document.createElement(\"div\");\n            \n            Object.assign(btn.style, {\n                aspectRatio: \"1/1\",\n                display: \"flex\",\n                alignItems: \"center\",\n                justifyContent: \"center\",\n                borderRadius: \"5px\",\n                fontSize: \"14px\",\n                fontWeight: \"bold\",\n                cursor: estaVendido ? \"not-allowed\" : \"pointer\",\n                backgroundColor: estaVendido ? \"#ff4d4d44\" : \"#2ecc71\",\n                color: estaVendido ? \"#ff4d4d\" : \"#fff\",\n                opacity: estaVendido ? \"0.4\" : \"1\",\n                transition: \"0.2s\"\n            });\n\n            btn.innerText = n;\n\n            if (!estaVendido) {\n                btn.onclick = () => {\n                    const msg = encodeURIComponent(`¡Hola! Quiero reservar el número ${n}. Mi nombre es: `);\n                    window.open(`https://wa.me/${WHATSAPP}?text=${msg}`, \"_blank\");\n                };\n            }\n            grid.appendChild(btn);\n        }\n    })();\n</script>\n"
}